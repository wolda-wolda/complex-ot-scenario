{
  "mode": {
    "strict-config": false
  },
  "plugins": {
    "md013": {
      "enabled": true,
      "line_length": 80,
      "code_blocks": false,
      "tables": false,
      "headings": false
    },
    "md026": {
      "enabled": false
    },
    "md028": {
      "enabled": false
    },
    "md029": {
      "enabled": false
    },
    "md036": {
      "enabled": false
    }
  }
}
